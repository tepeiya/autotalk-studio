# 复制为 .env 后填入真实 key
# ───────────────────────────────
# LLM 配置
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Ollama（本地）
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# 通义千问
DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-max

# ───────────────────────────────
# TTS 提供方
# Edge-TTS 默认零配置可用
EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural

# CosyVoice（自部署）
COSYVOICE_BASE_URL=http://127.0.0.1:9880

# GPT-SoVITS（自部署）
GPTSOVITS_BASE_URL=http://127.0.0.1:9880

# IndexTTS（自部署）
INDEXTTS_BASE_URL=http://127.0.0.1:8000

# ───────────────────────────────
# 数字人
MUSETALK_BASE_URL=http://127.0.0.1:8080
WAV2LIP_BASE_URL=http://127.0.0.1:8081
HEYGEM_BASE_URL=http://127.0.0.1:8082

# ───────────────────────────────
# 存储
STORAGE_ROOT=./storage

# ───────────────────────────────
# 服务
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
